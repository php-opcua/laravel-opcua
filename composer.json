{
    "name": "php-opcua/laravel-opcua",
    "description": "Laravel integration for OPC UA client with optional session manager support",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "GianfriAur",
            "email": "gianfri.aur@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "php-opcua/opcua-client": "^4.0.0",
        "php-opcua/opcua-session-manager": "^4.0.0",
        "psr/event-dispatcher": "^1.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "mockery/mockery": "^1.6",
        "illuminate/config": "^11.0|^12.0|^13.0",
        "vlucas/phpdotenv": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "PhpOpcua\\LaravelOpcua\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpOpcua\\LaravelOpcua\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhpOpcua\\LaravelOpcua\\OpcuaServiceProvider"
            ],
            "aliases": {
                "Opcua": "PhpOpcua\\LaravelOpcua\\Facades\\Opcua"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
