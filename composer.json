{
    "name": "gianfriaur/opcua-laravel-client",
    "description": "Laravel integration for OPC UA client with optional session manager support",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "GianfriAur",
            "email": "gianfri.aur@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "gianfriaur/opcua-php-client": "^3.0.0",
        "gianfriaur/opcua-php-client-session-manager": "^3.0.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "mockery/mockery": "^1.6",
        "illuminate/config": "^11.0|^12.0|^13.0",
        "vlucas/phpdotenv": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Gianfriaur\\OpcuaLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gianfriaur\\OpcuaLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gianfriaur\\OpcuaLaravel\\OpcuaServiceProvider"
            ],
            "aliases": {
                "Opcua": "Gianfriaur\\OpcuaLaravel\\Facades\\Opcua"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
